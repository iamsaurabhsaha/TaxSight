# AI Tax Prep Assistant - Environment Variables
# Copy this file to .env and fill in your values

# LLM Provider: "anthropic", "openai", "gemini", "ollama"
TAX_PREP_LLM_PROVIDER=anthropic

# API Keys (only needed for cloud providers)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Model override (optional - defaults are set per provider)
# TAX_PREP_MODEL=

# Ollama settings (only needed if using ollama provider)
# OLLAMA_BASE_URL=http://localhost:11434

# Database path (optional - defaults to ~/.ai-tax-prep/tax_prep.db)
# TAX_PREP_DB_PATH=

# PolicyEngine mode: "api" (default, free) or "local" (requires policyengine-us install)
TAX_PREP_PE_MODE=api
